{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "VoipGatewayPutRecordings",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:AbortMultipartUpload"
      ],
      "Resource": "arn:aws:s3:::esafx-staging-call-recordings-612524168745/recordings/*"
    },
    {
      "Sid": "CrmApiGetRecordings",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::esafx-staging-call-recordings-612524168745/recordings/*"
    },
    {
      "Sid": "ListBucketPrefix",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::esafx-staging-call-recordings-612524168745",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "recordings/*"
          ]
        }
      }
    }
  ]
}
